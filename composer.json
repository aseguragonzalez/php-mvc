{
    "authors": [
        {
            "name": "Alfonso Segura",
            "email": "a.segura.gonzalez@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PhpMvc\\": [
                "src/",
                "src/Web/",
                "src/Apps/",
                "src/Cli/",
                "src/Functional/",
                "src/DevTools/"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/Support/",
            "Tests\\Unit\\PhpMvc\\": [
                "tests/Web/",
                "tests/Apps/",
                "tests/Cli/",
                "tests/Functional/",
                "tests/DevTools/"
            ]
        }
    },
    "bin": [
        "bin/mvc"
    ],
    "config": {
        "platform": {
            "php": "8.4"
        }
    },
    "description": "Lightweight PHP MVC Framework",
    "homepage": "https://github.com/aseguragonzalez/php-mvc",
    "license": "MIT",
    "minimum-stability": "stable",
    "name": "aseguragonzalez/php-mvc",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "psr/container": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "friendsofphp/php-cs-fixer": "^3.95",
        "mikey179/vfsstream": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5"
    },
    "scripts": {
        "test": "phpunit",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "stan": "phpstan analyse",
        "check": [
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "support": {
        "docs": "https://github.com/aseguragonzalez/php-mvc/tree/main/docs",
        "source": "https://github.com/aseguragonzalez/php-mvc.git"
    },
    "type": "library"
}
