{
  "configurations": [
    {
      "name": "Listen (Local)",
      "port": 9003,
      "request": "launch",
      "runtimeArgs": [
        "-dxdebug.mode=debug"
      ],
      "type": "php"
    },
    {
      "name": "Listen (Container)",
      "pathMappings": {
        "/app": "${workspaceFolder}"
      },
      "port": 9003,
      "request": "launch",
      "type": "php"
    },
    {
      "args": [
        "--configuration",
        "phpunit.xml"
      ],
      "cwd": "${workspaceFolder}",
      "name": "PHPUnit: suite (Local)",
      "port": 9003,
      "program": "${workspaceFolder}/vendor/bin/phpunit",
      "request": "launch",
      "runtimeArgs": [
        "-dxdebug.mode=debug"
      ],
      "type": "php"
    },
    {
      "args": [
        "--configuration",
        "phpunit.xml",
        "${file}"
      ],
      "cwd": "${workspaceFolder}",
      "name": "PHPUnit: file (Local)",
      "port": 9003,
      "program": "${workspaceFolder}/vendor/bin/phpunit",
      "request": "launch",
      "runtimeArgs": [
        "-dxdebug.mode=debug"
      ],
      "type": "php"
    }
  ],
  "version": "0.2.0"
}
